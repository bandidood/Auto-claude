# ─── Telegram (required) ────────────────────────────────────────────────────
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID — run the bot and send /chatid to get this
ALLOWED_CHAT_ID=

# ─── Voice STT — Groq Whisper (optional) ────────────────────────────────────
# Free tier at https://console.groq.com
# Used for: transcribing voice notes you send to the bot
GROQ_API_KEY=

# ─── Voice TTS — ElevenLabs (optional) ──────────────────────────────────────
# Free tier at https://elevenlabs.io
# Used for: bot replying with audio via /voice toggle
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ─── Video analysis — Google Gemini (optional) ──────────────────────────────
# Free tier at https://aistudio.google.com
# Used for: analyzing video files sent to the bot
GOOGLE_API_KEY=

# ─── Multi-user (optional) ──────────────────────────────────────────────────
# Comma-separated list of allowed Telegram chat IDs
# Leave empty to use ALLOWED_CHAT_ID only
ALLOWED_CHAT_IDS=

# ─── Logging ────────────────────────────────────────────────────────────────
# Log level: trace, debug, info, warn, error
LOG_LEVEL=info
